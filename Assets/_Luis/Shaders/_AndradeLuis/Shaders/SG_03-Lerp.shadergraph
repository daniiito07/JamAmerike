{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "a9d573ff8e034edaafec0499b1c02177",
    "m_Title": "Osilacion de colores",
    "m_Content": "Con el tiempo logramos que este genere el intercambio de colores, el multiply nos sirve para poder hacer el tiempo mas rapido y que cambie a mayor velocidad, con el sine (seno) hacemos que este vaya de valor 1 a 0 para poder cambiar los colores o 'escenas' , el absolute nos ayuda a que nada sea negativo siempre tendremos valores positivos, el Step nos ayuda a eliminar variaciones entre colores dandonos solo los que pusimos sin degradar estos mismos, y al final utilizamos un lerp para poder cambiar los colores y conseguir un nuevo estado.\nStep elimina valores intermedios",
    "m_TextSize": 0,
    "m_Theme": 1,
    "m_Position": {
        "serializedVersion": "2",
        "x": 568.0,
        "y": -3764.0,
        "width": 344.79998779296877,
        "height": 177.599853515625
    },
    "m_Group": {
        "m_Id": "98265faa05a64503811f21e08690ea29"
    }
}

