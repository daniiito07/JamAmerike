{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "c7e74f7aa2f84a6d893e44b95d229df3",
    "m_Title": "Lerp Simple",
    "m_Content": "Con el boolean podemos switchear entre los colores dependiendo si es verdadero o falso\n\nCon el Float podemos obtener una combinacion de ambos dependiendo el numero entre mas cerca del 1 es el primer color y viceversa\n\nCon el Slider podemos hacer lo mismo que el float pero ahora nostros definimos un min - max para los colores",
    "m_TextSize": 0,
    "m_Theme": 1,
    "m_Position": {
        "serializedVersion": "2",
        "x": 1869.5999755859375,
