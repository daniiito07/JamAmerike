{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "9e5f530184094364844485e0eedca0ed",
    "m_Title": "Como usar",
    "m_Content": "Cuando usamo el seno nos da una curva pasando por 1 y -1 y queremos controlar la frecuencia e Amplitud\n\nCon time cambia a positivos y negativos y si lo multiplicamos lo que hacemos e modificar la frecuencia\n\nFrequency es para hacer que se mueva tanto rapido como lento \n\nAmplitude es para hacer que se mueva de arriba a abajo\n\n",
    "m_TextSize": 0,
    "m_Theme": 0,
    "m_Position": {
        "serializedVersion": "2",
        "x": -3966.916748046875,
        "y": 778.8773803710938,
        "width": 200.0,
        "height": 160.0
    },
    "m_Group": {
        "m_Id": ""
    }
}

